<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.lostandfound.mapper.AdminMapper">
    <!-- 注册管理员 -->
    <insert id="insert">
        insert into admin(username, password, email, phone)
        values (#{admin.username},#{admin.password},#{admin.email},#{admin.phone})
    </insert>

    <select id="selectByEmail" resultType="org.example.lostandfound.pojo.Admin">
        select * from admin where email=#{email}
    </select>

    <select id="selectByPhone" resultType="org.example.lostandfound.pojo.Admin">
        select * from admin where phone=#{phone}
    </select>


</mapper>