<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.lostandfound.mapper.UserMapper">

    <select id="selectByUsername" resultType="org.example.lostandfound.pojo.User">
        select * from user where username=#{username}
    </select>

    <select id="selectByEmail" resultType="org.example.lostandfound.pojo.User">
        select * from user where email=#{email}
    </select>
    <select id="selectByPhone" resultType="org.example.lostandfound.pojo.User">
        select * from user where phone=#{phone}
    </select>


</mapper>